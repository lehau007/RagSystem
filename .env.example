# ─────────────────────────────────────────────────────────────────────────────
# Required API Keys
# ─────────────────────────────────────────────────────────────────────────────

# Groq Cloud — used for query decomposition and answer synthesis
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — used for PDF → Markdown preprocessing and RAGAS evaluation
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Hugging Face — used to download the embedding model (google/embeddinggemma-300M)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# LangSmith Observability (optional)
# Enable to get full trace visibility in the LangSmith dashboard.
# Leave LANGCHAIN_TRACING_V2=false (or unset) to disable — no account needed.
# ─────────────────────────────────────────────────────────────────────────────

# Set to "true" to enable LangSmith tracing
LANGCHAIN_TRACING_V2=false

# LangSmith API key — required only when LANGCHAIN_TRACING_V2=true
# Get yours at: https://smith.langchain.com/settings
LANGCHAIN_API_KEY=

# Project name shown in the LangSmith dashboard
LANGCHAIN_PROJECT=hust-rag-system
